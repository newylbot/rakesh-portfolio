# Public canonical site URL (used for SEO, sitemap, robots, Open Graph).
# Replace with your real production domain when deploying.
NEXT_PUBLIC_SITE_URL=https://example.com

# Optional: only set this if you connect a REAL contact form backend
# (e.g. Formspree, a serverless function, or your own API).
# If left empty, the contact form shows a graceful "not yet configured" state.
# CONTACT_FORM_ENDPOINT=
NEXT_PUBLIC_CONTACT_FORM_ENDPOINT=
