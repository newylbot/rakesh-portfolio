# Public site URL used for canonical links, sitemap, robots, and OG metadata.
# Set this to your real production domain when deploying.
NEXT_PUBLIC_SITE_URL=https://your-domain.com

# Optional: a real contact form backend endpoint (e.g. Formspree, a serverless
# function, or your own API). Leave unset until a real endpoint exists.
# The contact form degrades gracefully to a mailto fallback when this is empty.
# CONTACT_FORM_ENDPOINT=
