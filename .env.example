# Public site URL — used for canonical URLs, sitemap, robots, and OG tags.
NEXT_PUBLIC_SITE_URL=https://your-domain.com

# OPTIONAL: A real contact form backend endpoint (e.g. Formspree, a Resend proxy,
# or your own API). If left blank, the contact form will NOT fake a submission —
# it will ask visitors to email directly instead.
CONTACT_FORM_ENDPOINT=
